# Anthea environment configuration.
# Copy to `.env` and fill in. `.env` is gitignored.

# --- Notion intake integration (server-side) -------------------------------
# Used by api/intake.mjs to write contact-form submissions to Notion.
# Create a Notion internal integration (https://www.notion.so/my-integrations),
# then share BOTH databases with it.
#
# If NOTION_TOKEN is unset, the form runs in DRY-RUN mode: valid submissions are
# logged to the server console and accepted, so local dev works without secrets.
#
# Property names must match exactly (spaces and capitalization included).
#
# Startups database ("I'm hiring"):
#   Name          — Title
#   Organization  — Text   (the company name)
#   Email         — Email
#   Roles hiring  — Text
#   Role type     — Text
#   Message       — Text
#   Source        — Text   (first-touch UTM attribution)
#
# Candidates database ("I'm looking for a role"):
#   Name          — Title
#   Email         — Email
#   University    — Text
#   LinkedIn      — Text
#   Role wanted   — Text
#   Experience    — Text
#   Message       — Text
#   Source        — Text   (first-touch UTM attribution)
#
# NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTION_STARTUPS_DB_ID=00000000000000000000000000000000
# NOTION_CANDIDATES_DB_ID=00000000000000000000000000000000
# NOTION_VERSION=2022-06-28

# --- Frontend --------------------------------------------------------------
# Optional: override the intake API base used by the contact form. Defaults to
# /api (same-origin), which both the dev server and serve.mjs handle.
# VITE_API_BASE_URL=https://antheatalent.com/api
